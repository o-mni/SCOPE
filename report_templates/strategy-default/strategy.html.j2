<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>{{ plan.title | default("Assessment Strategy Plan") }}</title>
  <link rel="stylesheet" href="assets/styles.css" />
</head>
<body>

{# Running header #}
<div id="page-header">
  <span class="header-left">{{ plan.title | default("Assessment Strategy") }}</span>
  <span class="header-right">Assessment Strategy Plan</span>
</div>

{# ══════════════════════════════════════════════════════════════════════════
   COVER PAGE
══════════════════════════════════════════════════════════════════════════ #}
<div class="cover">
  <div class="cover-inner">
    <div class="cover-doc-type">Assessment Strategy Plan</div>
    <h1>{{ plan.title | default("Security Assessment Strategy") }}</h1>
    <div class="cover-subtitle">{{ plan.subtitle | default("Pre-engagement planning document for automated security assessment") }}</div>

    <div class="cover-meta-grid">
      <div class="cover-meta-row">
        <div class="cover-meta-label">Target System</div>
        <div class="cover-meta-value">{{ plan.target | default("—") }}</div>
      </div>
      <div class="cover-meta-row">
        <div class="cover-meta-label">Prepared By</div>
        <div class="cover-meta-value">{{ plan.author | default("SCOPE Platform") }}</div>
      </div>
      <div class="cover-meta-row">
        <div class="cover-meta-label">Version</div>
        <div class="cover-meta-value">{{ plan.version | default("1.0") }}</div>
      </div>
      <div class="cover-meta-row">
        <div class="cover-meta-label">Created</div>
        <div class="cover-meta-value">{{ plan.created_at | default("—") }}</div>
      </div>
      <div class="cover-meta-row">
        <div class="cover-meta-label">Status</div>
        <div class="cover-meta-value">{{ plan.status | default("Draft") }}</div>
      </div>
      <div class="cover-meta-row">
        <div class="cover-meta-label">Plan ID</div>
        <div class="cover-meta-value">SCOPE-STRAT-{{ plan.id | default("—") }}</div>
      </div>
    </div>
  </div>

  <div class="cover-footer">
    <span class="cover-footer-brand">SCOPE — Security Configuration Observation and Protection Engine</span>
    <span class="cover-footer-date">Generated {{ generated_at | default("—") }}</span>
  </div>
</div>

{# ══════════════════════════════════════════════════════════════════════════
   TABLE OF CONTENTS
══════════════════════════════════════════════════════════════════════════ #}
{% if render.include_toc %}
<div class="toc">
  <div class="toc-title">Table of Contents</div>
  <ol class="toc-list">
    <li class="toc-item"><span class="toc-item-num">1</span><span class="toc-item-title">Purpose &amp; Objectives</span></li>
    <li class="toc-item"><span class="toc-item-num">2</span><span class="toc-item-title">Assessment Scope</span></li>
    <li class="toc-item"><span class="toc-item-num">3</span><span class="toc-item-title">Methodology</span></li>
    {% if plan.milestones %}<li class="toc-item"><span class="toc-item-num">4</span><span class="toc-item-title">Schedule &amp; Milestones</span></li>{% endif %}
    <li class="toc-item"><span class="toc-item-num">{{ "5" if plan.milestones else "4" }}</span><span class="toc-item-title">Risk Acceptance Criteria</span></li>
    <li class="toc-item"><span class="toc-item-num">{{ "6" if plan.milestones else "5" }}</span><span class="toc-item-title">Roles &amp; Responsibilities</span></li>
    <li class="toc-item"><span class="toc-item-num">{{ "7" if plan.milestones else "6" }}</span><span class="toc-item-title">Expected Deliverables</span></li>
    {% if plan.approvers %}<li class="toc-item"><span class="toc-item-title">Approval &amp; Sign-off</span></li>{% endif %}
    <li class="toc-item"><span class="toc-item-title">Disclaimer</span></li>
  </ol>
</div>
{% endif %}

{# ══════════════════════════════════════════════════════════════════════════
   1. PURPOSE & OBJECTIVES
══════════════════════════════════════════════════════════════════════════ #}
<div class="section page-break" id="purpose">
  <div class="section-header">
    <span class="section-number">1</span>
    <h2>Purpose &amp; Objectives</h2>
  </div>

  <p>{{ plan.purpose | default("This document defines the strategy, scope, and approach for the planned security assessment. It is intended to align stakeholders on objectives, methodology, and expected outcomes before the assessment begins.") }}</p>

  <h3>Objectives</h3>
  {% if plan.objectives %}
  <ul>{% for obj in plan.objectives %}<li>{{ obj }}</li>{% endfor %}</ul>
  {% else %}
  <ul>
    <li>Identify security misconfigurations and weaknesses in the target system.</li>
    <li>Evaluate compliance against the organisational security baseline.</li>
    <li>Provide actionable remediation guidance for all identified findings.</li>
    <li>Establish a current security posture snapshot for tracking improvement over time.</li>
  </ul>
  {% endif %}

  {% if plan.background %}
  <h3>Background</h3>
  <p>{{ plan.background }}</p>
  {% endif %}
</div>

{# ══════════════════════════════════════════════════════════════════════════
   2. ASSESSMENT SCOPE
══════════════════════════════════════════════════════════════════════════ #}
<div class="section" id="scope">
  <div class="section-header">
    <span class="section-number">2</span>
    <h2>Assessment Scope</h2>
  </div>

  <h3>In Scope</h3>
  {% if plan.in_scope %}
  <ul>{% for item in plan.in_scope %}<li>{{ item }}</li>{% endfor %}</ul>
  {% else %}
  <ul>
    <li>Operating system configuration and kernel parameters</li>
    <li>Installed packages and service versions</li>
    <li>Running services and open network ports</li>
    <li>User accounts, groups, sudo rules, and SSH configuration</li>
    <li>File system permissions and SUID/SGID binaries</li>
    <li>Firewall and network filtering rules</li>
    <li>Logging and audit configuration</li>
    <li>Authentication and PAM configuration</li>
  </ul>
  {% endif %}

  <h3>Out of Scope</h3>
  {% if plan.out_of_scope %}
  <ul>{% for item in plan.out_of_scope %}<li>{{ item }}</li>{% endfor %}</ul>
  {% else %}
  <p class="text-muted">No explicit exclusions defined. All default SCOPE modules are in scope unless otherwise constrained.</p>
  {% endif %}

  <h3>Constraints &amp; Assumptions</h3>
  {% if plan.constraints %}
  <ul>{% for c in plan.constraints %}<li>{{ c }}</li>{% endfor %}</ul>
  {% else %}
  <ul>
    <li>Assessment will be conducted without root privileges unless explicitly granted.</li>
    <li>No active exploitation or offensive techniques will be used.</li>
    <li>All data collection is read-only and non-destructive.</li>
    <li>System availability will not be impacted during assessment.</li>
  </ul>
  {% endif %}
</div>

{# ══════════════════════════════════════════════════════════════════════════
   3. METHODOLOGY
══════════════════════════════════════════════════════════════════════════ #}
<div class="section page-break" id="methodology">
  <div class="section-header">
    <span class="section-number">3</span>
    <h2>Methodology</h2>
  </div>

  <p>{{ plan.methodology_overview | default("SCOPE performs a structured, non-intrusive audit of local system state using OS-native interfaces and configuration file inspection. No network scanning or active exploitation is performed.") }}</p>

  <h3>Assessment Phases</h3>
  <div class="phase-list">
    {% if plan.phases %}
    {% for phase in plan.phases %}
    <div class="phase-card">
      <div class="phase-card-header phase-{{ loop.index }}">
        <span class="phase-num">Phase {{ loop.index }}</span>
        <span class="phase-name">{{ phase.name }}</span>
      </div>
      <div class="phase-card-body">
        <p>{{ phase.description | default("") }}</p>
        {% if phase.tasks %}<ul>{% for task in phase.tasks %}<li>{{ task }}</li>{% endfor %}</ul>{% endif %}
      </div>
    </div>
    {% endfor %}
    {% else %}
    <div class="phase-card">
      <div class="phase-card-header phase-1">
        <span class="phase-num">Phase 1</span>
        <span class="phase-name">Reconnaissance &amp; Data Collection</span>
      </div>
      <div class="phase-card-body">
        <p>Collect system metadata, installed packages, running services, and configuration files using SCOPE's data collection modules.</p>
      </div>
    </div>
    <div class="phase-card">
      <div class="phase-card-header phase-2">
        <span class="phase-num">Phase 2</span>
        <span class="phase-name">Configuration Analysis</span>
      </div>
      <div class="phase-card-body">
        <p>Evaluate collected data against security baseline rules, known misconfiguration patterns, and hardening benchmarks.</p>
      </div>
    </div>
    <div class="phase-card">
      <div class="phase-card-header phase-3">
        <span class="phase-num">Phase 3</span>
        <span class="phase-name">Finding Classification &amp; Triage</span>
      </div>
      <div class="phase-card-body">
        <p>Classify all findings by severity, assign remediation priority, and group by category for reporting.</p>
      </div>
    </div>
    <div class="phase-card">
      <div class="phase-card-header phase-4">
        <span class="phase-num">Phase 4</span>
        <span class="phase-name">Reporting &amp; Handover</span>
      </div>
      <div class="phase-card-body">
        <p>Generate the assessment report, review findings with stakeholders, and deliver remediation guidance.</p>
      </div>
    </div>
    {% endif %}
  </div>

  {% if plan.modules %}
  <h3>Planned Modules</h3>
  <div class="module-grid">
    {% for mod in plan.modules %}
    <div class="module-item">
      <div class="mod-id">{{ mod.id }}</div>
      <div class="mod-name">{{ mod.name }}</div>
    </div>
    {% endfor %}
  </div>
  {% endif %}

  {% if plan.tools %}
  <h3>Tools &amp; Techniques</h3>
  <table>
    <thead><tr><th>Tool / Technique</th><th>Purpose</th><th>Notes</th></tr></thead>
    <tbody>
      {% for tool in plan.tools %}
      <tr>
        <td class="text-mono">{{ tool.name }}</td>
        <td>{{ tool.purpose }}</td>
        <td class="text-muted">{{ tool.notes | default("—") }}</td>
      </tr>
      {% endfor %}
    </tbody>
  </table>
  {% endif %}
</div>

{# ══════════════════════════════════════════════════════════════════════════
   4. SCHEDULE (optional)
══════════════════════════════════════════════════════════════════════════ #}
{% if plan.milestones %}
<div class="section" id="schedule">
  <div class="section-header">
    <span class="section-number">4</span>
    <h2>Schedule &amp; Milestones</h2>
  </div>
  <div class="milestone-list">
    {% for ms in plan.milestones %}
    <div class="milestone">
      <div class="milestone-date">{{ ms.date | default("TBD") }}</div>
      <div class="milestone-title">{{ ms.title }}</div>
      {% if ms.description %}<div class="milestone-desc">{{ ms.description }}</div>{% endif %}
    </div>
    {% endfor %}
  </div>
</div>
{% endif %}

{# ══════════════════════════════════════════════════════════════════════════
   RISK ACCEPTANCE CRITERIA
══════════════════════════════════════════════════════════════════════════ #}
<div class="section" id="risk-acceptance">
  <div class="section-header">
    <span class="section-number">{{ "5" if plan.milestones else "4" }}</span>
    <h2>Risk Acceptance Criteria</h2>
  </div>

  <table>
    <thead><tr><th>Severity</th><th>Required Response</th><th>SLA</th></tr></thead>
    <tbody>
      <tr><td><span class="badge badge-critical">Critical</span></td><td>Immediate escalation — owner approval required before acceptance</td><td>24 hours</td></tr>
      <tr><td><span class="badge badge-high">High</span></td><td>Owner approval before acceptance</td><td>72 hours</td></tr>
      <tr><td><span class="badge badge-medium">Medium</span></td><td>Log, assign, and schedule remediation</td><td>14 days</td></tr>
      <tr><td><span class="badge badge-low">Low</span></td><td>Log and review in next cycle</td><td>90 days</td></tr>
      <tr><td><span class="badge badge-info">Info</span></td><td>Informational — no action required</td><td>N/A</td></tr>
    </tbody>
  </table>
</div>

{# ══════════════════════════════════════════════════════════════════════════
   ROLES & RESPONSIBILITIES
══════════════════════════════════════════════════════════════════════════ #}
<div class="section" id="roles">
  <div class="section-header">
    <span class="section-number">{{ "6" if plan.milestones else "5" }}</span>
    <h2>Roles &amp; Responsibilities</h2>
  </div>

  {% if plan.roles %}
  <table>
    <thead><tr><th>Role</th><th>Name / Team</th><th>Responsibilities</th></tr></thead>
    <tbody>
      {% for role in plan.roles %}
      <tr>
        <td><strong>{{ role.title }}</strong></td>
        <td>{{ role.assignee | default("TBD") }}</td>
        <td>{{ role.responsibilities | default("—") }}</td>
      </tr>
      {% endfor %}
    </tbody>
  </table>
  {% else %}
  <table>
    <thead><tr><th>Role</th><th>Responsibilities</th></tr></thead>
    <tbody>
      <tr><td><strong>Assessment Lead</strong></td><td>Configure and execute the assessment; review all findings; deliver the final report.</td></tr>
      <tr><td><strong>System Owner</strong></td><td>Grant access; review and accept/reject findings; approve remediation actions.</td></tr>
      <tr><td><strong>Security Team</strong></td><td>Validate critical findings; advise on remediation; sign off on risk acceptance decisions.</td></tr>
      <tr><td><strong>Operations</strong></td><td>Implement remediation steps; confirm resolution; retest as required.</td></tr>
    </tbody>
  </table>
  {% endif %}
</div>

{# ══════════════════════════════════════════════════════════════════════════
   DELIVERABLES
══════════════════════════════════════════════════════════════════════════ #}
<div class="section" id="deliverables">
  <div class="section-header">
    <span class="section-number">{{ "7" if plan.milestones else "6" }}</span>
    <h2>Expected Deliverables</h2>
  </div>

  {% if plan.deliverables %}
  <ul>
    {% for d in plan.deliverables %}
    <li><strong>{{ d.name }}</strong>{% if d.description %} — {{ d.description }}{% endif %}{% if d.due %} <span class="text-muted">(due: {{ d.due }})</span>{% endif %}</li>
    {% endfor %}
  </ul>
  {% else %}
  <ul>
    <li><strong>Preliminary Assessment Report (PDF)</strong> — Full findings report with severity breakdown and remediation guidance.</li>
    <li><strong>Raw Findings Export</strong> — Machine-readable JSON export of all findings.</li>
    <li><strong>Executive Summary</strong> — One-page summary for non-technical stakeholders.</li>
    <li><strong>Remediation Tracker</strong> — Prioritised list of remediation tasks with ownership and SLA assignments.</li>
  </ul>
  {% endif %}
</div>

{# ══════════════════════════════════════════════════════════════════════════
   APPROVAL (optional)
══════════════════════════════════════════════════════════════════════════ #}
{% if plan.approvers %}
<div class="section page-break" id="approval">
  <div class="section-header">
    <h2>Approval &amp; Sign-off</h2>
  </div>
  <p>By signing below, the named individuals confirm they have reviewed this Assessment Strategy Plan and authorise the assessment to proceed as described.</p>
  <div class="approval-block">
    {% for approver in plan.approvers %}
    <div class="signature-box">
      <div class="sig-label">{{ approver.role | default("Approver") }}</div>
      <div class="sig-line"></div>
      <div class="sig-name">{{ approver.name | default("___________________________") }}</div>
      <div class="text-muted">Date: _______________</div>
    </div>
    {% endfor %}
  </div>
</div>
{% endif %}

{# ══════════════════════════════════════════════════════════════════════════
   DISCLAIMER
══════════════════════════════════════════════════════════════════════════ #}
<div class="section page-break" id="disclaimer">
  <h2>Disclaimer</h2>
  <div class="disclaimer">
    {{ disclaimer | default("This Assessment Strategy Plan is a pre-engagement document generated by SCOPE. It does not constitute a legal authorisation to conduct testing. Prior written approval from the system owner must be obtained before any assessment is initiated. This document is for internal planning purposes only.") }}
  </div>
  <p class="text-muted mt-md">
    Generated by <strong>SCOPE</strong> — Security Configuration Observation and Protection Engine
    {% if generated_at %} &mdash; {{ generated_at }}{% endif %}
  </p>
</div>

</body>
</html>
