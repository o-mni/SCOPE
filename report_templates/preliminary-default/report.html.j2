<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>{{ assessment.title | default("Security Assessment Report") }}</title>
  <link rel="stylesheet" href="assets/styles.css" />
</head>
<body>

{# Running page header — rendered on every page except cover #}
<div id="page-header">
  <span class="header-left">{{ assessment.title | default("Security Assessment") }}</span>
  <span class="header-right">Preliminary Security Assessment Report</span>
</div>

{# ══════════════════════════════════════════════════════════════════════════
   COVER PAGE
══════════════════════════════════════════════════════════════════════════ #}
<div class="cover">
  <div class="cover-inner">
    <div class="cover-label">Preliminary Security Assessment</div>
    <h1>{{ assessment.title | default("Security Assessment Report") }}</h1>
    <div class="cover-subtitle">{{ assessment.summary | default("Automated security configuration assessment conducted by the SCOPE platform.") }}</div>

    <div class="cover-meta-grid">
      <div class="cover-meta-row">
        <div class="cover-meta-label">Target System</div>
        <div class="cover-meta-value">{{ assessment.target | default("—") }}</div>
      </div>
      <div class="cover-meta-row">
        <div class="cover-meta-label">Assessed By</div>
        <div class="cover-meta-value">{{ assessment.assessor | default("SCOPE Automated Engine") }}</div>
      </div>
      <div class="cover-meta-row">
        <div class="cover-meta-label">Assessment Date</div>
        <div class="cover-meta-value">{{ assessment.date | default("—") }}</div>
      </div>
      <div class="cover-meta-row">
        <div class="cover-meta-label">Classification</div>
        <div class="cover-meta-value">{{ assessment.classification | default("Internal Use Only") }}</div>
      </div>
      <div class="cover-meta-row">
        <div class="cover-meta-label">Report ID</div>
        <div class="cover-meta-value">SCOPE-{{ assessment.id | default("—") }}</div>
      </div>
    </div>
  </div>

  <div class="cover-footer">
    <span class="cover-footer-brand">SCOPE — Security Configuration Observation and Protection Engine</span>
    <span class="cover-footer-date">Generated {{ generated_at | default("—") }}</span>
  </div>
</div>

{# ══════════════════════════════════════════════════════════════════════════
   TABLE OF CONTENTS
══════════════════════════════════════════════════════════════════════════ #}
{% if render.include_toc %}
<div class="toc">
  <div class="toc-title">Table of Contents</div>
  <ol class="toc-list">
    <li class="toc-item"><span class="toc-item-num">1</span><span class="toc-item-title">Executive Summary</span></li>
    <li class="toc-item"><span class="toc-item-num">2</span><span class="toc-item-title">Scope &amp; Methodology</span></li>
    <li class="toc-item"><span class="toc-item-num">3</span><span class="toc-item-title">System Overview</span></li>
    <li class="toc-item">
      <span class="toc-item-num">4</span><span class="toc-item-title">Findings</span>
      <ol class="toc-sub">
        {% for sev in ["critical","high","medium","low","informational"] %}
        {% if findings_by_severity[sev] | default([]) | length > 0 %}
        <li class="toc-item"><span class="toc-item-title">{{ sev | capitalize }} ({{ findings_by_severity[sev] | length }})</span></li>
        {% endif %}
        {% endfor %}
      </ol>
    </li>
    <li class="toc-item"><span class="toc-item-num">5</span><span class="toc-item-title">Assessment Coverage</span></li>
    <li class="toc-item"><span class="toc-item-num">6</span><span class="toc-item-title">Recommendations</span></li>
    {% if notes %}<li class="toc-item"><span class="toc-item-num">7</span><span class="toc-item-title">Analyst Notes</span></li>{% endif %}
    <li class="toc-item"><span class="toc-item-num">{% if notes %}8{% else %}7{% endif %}</span><span class="toc-item-title">Disclaimer</span></li>
  </ol>
</div>
{% endif %}

{# ══════════════════════════════════════════════════════════════════════════
   1. EXECUTIVE SUMMARY
══════════════════════════════════════════════════════════════════════════ #}
<div class="section page-break" id="executive-summary">
  <div class="section-header">
    <span class="section-number">1</span>
    <h2>Executive Summary</h2>
  </div>

  <p>{{ assessment.summary | default("This report presents the findings of an automated preliminary security assessment conducted by the SCOPE platform. The system was evaluated against a baseline of security configuration checks and known vulnerability indicators.") }}</p>

  <div class="severity-summary">
    {% for sev in ["critical","high","medium","low","informational"] %}
    <div class="severity-card {{ sev }}">
      <span class="sev-count">{{ findings_by_severity[sev] | default([]) | length }}</span>
      <span class="sev-label">{{ sev | capitalize }}</span>
    </div>
    {% endfor %}
  </div>

  {% set total = findings | length %}
  {% set critical_n = findings_by_severity["critical"] | default([]) | length %}
  <p>
    A total of <strong>{{ total }} finding{{ "s" if total != 1 }}</strong> were identified during this assessment.
    {% if critical_n > 0 %}
    <strong>{{ critical_n }} critical finding{{ "s" if critical_n != 1 }}</strong> require immediate attention.
    {% endif %}
  </p>
</div>

{# ══════════════════════════════════════════════════════════════════════════
   2. SCOPE & METHODOLOGY
══════════════════════════════════════════════════════════════════════════ #}
<div class="section" id="scope-methodology">
  <div class="section-header">
    <span class="section-number">2</span>
    <h2>Scope &amp; Methodology</h2>
  </div>

  <h3>Assessment Scope</h3>
  <p>{{ assessment.scope | default("The assessment covered the system configuration, installed packages, running services, network exposure, user accounts, file permissions, and security hardening baseline of the target system.") }}</p>

  {% if assessment.out_of_scope %}
  <h3>Out of Scope</h3>
  <p>{{ assessment.out_of_scope }}</p>
  {% endif %}

  <h3>Methodology</h3>
  <p>{{ assessment.methodology | default("SCOPE performed a non-intrusive, read-only audit of local system state. No exploits or active probes were used. All data was collected via OS-native interfaces and configuration files. The assessment was conducted without causing any disruption to system availability.") }}</p>

  {% if assessment.modules_used %}
  <h4>Modules Executed</h4>
  <table class="index-table">
    <thead>
      <tr><th>Module</th><th>Description</th><th>Status</th></tr>
    </thead>
    <tbody>
      {% for mod in assessment.modules_used %}
      <tr>
        <td class="text-mono">{{ mod.id }}</td>
        <td>{{ mod.description }}</td>
        <td><span class="badge badge-{{ mod.status | lower }}">{{ mod.status }}</span></td>
      </tr>
      {% endfor %}
    </tbody>
  </table>
  {% endif %}
</div>

{# ══════════════════════════════════════════════════════════════════════════
   3. SYSTEM OVERVIEW
══════════════════════════════════════════════════════════════════════════ #}
<div class="section" id="system-overview">
  <div class="section-header">
    <span class="section-number">3</span>
    <h2>System Overview</h2>
  </div>

  {% if system %}
  <table class="info-table">
    <tbody>
      <tr><td>Hostname</td><td class="text-mono">{{ system.hostname | default("—") }}</td></tr>
      <tr><td>Operating System</td><td>{{ system.os | default("—") }}</td></tr>
      <tr><td>Kernel</td><td class="text-mono">{{ system.kernel | default("—") }}</td></tr>
      <tr><td>Architecture</td><td>{{ system.arch | default("—") }}</td></tr>
      <tr><td>Uptime</td><td>{{ system.uptime | default("—") }}</td></tr>
      <tr><td>Active Users</td><td>{{ system.users | default("—") }}</td></tr>
      <tr><td>IP Addresses</td><td class="text-mono">{{ system.ip_addresses | join(", ") if system.ip_addresses else "—" }}</td></tr>
    </tbody>
  </table>
  {% else %}
  <p class="text-muted">System information was not collected during this assessment.</p>
  {% endif %}
</div>

{# ══════════════════════════════════════════════════════════════════════════
   4. FINDINGS
══════════════════════════════════════════════════════════════════════════ #}
<div class="section page-break" id="findings">
  <div class="section-header">
    <span class="section-number">4</span>
    <h2>Findings</h2>
  </div>

  {% if findings | length == 0 %}
  <div class="callout">No findings were recorded during this assessment.</div>
  {% else %}

  <h3>Finding Index</h3>
  <table class="index-table">
    <thead>
      <tr><th>#</th><th>ID</th><th>Title</th><th>Severity</th><th>Category</th></tr>
    </thead>
    <tbody>
      {% for f in findings %}
      <tr>
        <td>{{ loop.index }}</td>
        <td class="text-mono">{{ f.id }}</td>
        <td>{{ f.title }}</td>
        <td><span class="badge badge-{{ f.severity | lower }}">{{ f.severity }}</span></td>
        <td>{{ f.category | default("—") }}</td>
      </tr>
      {% endfor %}
    </tbody>
  </table>

  {# — Findings grouped by severity — #}
  {% for sev in ["critical","high","medium","low","informational"] %}
  {% set group = findings_by_severity[sev] | default([]) %}
  {% if group | length > 0 %}

  <h3><span class="badge badge-{{ sev }}">{{ sev | capitalize }}</span> &nbsp;Findings ({{ group | length }})</h3>

  {% for f in group %}
  <div class="finding-card">
    <div class="finding-card-header sev-{{ f.severity | lower }}">
      <span class="finding-id">{{ f.id }}</span>
      <span class="finding-title">{{ f.title }}</span>
      <span class="badge badge-{{ f.severity | lower }}">{{ f.severity }}</span>
    </div>
    <div class="finding-card-body">
      <div class="finding-dl">
        <div class="finding-row">
          <div class="finding-dt">Description</div>
          <div class="finding-dd">{{ f.description | default("No description provided.") }}</div>
        </div>
        <div class="finding-row">
          <div class="finding-dt">Category</div>
          <div class="finding-dd">{{ f.category | default("—") }}</div>
        </div>
        {% if f.affected_item %}
        <div class="finding-row">
          <div class="finding-dt">Affected Item</div>
          <div class="finding-dd text-mono">{{ f.affected_item }}</div>
        </div>
        {% endif %}
        {% if f.evidence %}
        <div class="finding-row">
          <div class="finding-dt">Evidence</div>
          <div class="finding-dd"><pre>{{ f.evidence }}</pre></div>
        </div>
        {% endif %}
        {% if f.remediation %}
        <div class="finding-row">
          <div class="finding-dt">Remediation</div>
          <div class="finding-dd">{{ f.remediation }}</div>
        </div>
        {% endif %}
        {% if f.references %}
        <div class="finding-row">
          <div class="finding-dt">References</div>
          <div class="finding-dd">
            {% for ref in f.references %}<div>{{ ref }}</div>{% endfor %}
          </div>
        </div>
        {% endif %}
      </div>
    </div>
  </div>
  {% endfor %}
  {% endif %}
  {% endfor %}

  {% endif %}
</div>

{# ══════════════════════════════════════════════════════════════════════════
   5. COVERAGE
══════════════════════════════════════════════════════════════════════════ #}
<div class="section page-break" id="coverage">
  <div class="section-header">
    <span class="section-number">5</span>
    <h2>Assessment Coverage</h2>
  </div>

  {% if coverage %}
  <div class="coverage-grid">
    {% for item in coverage %}
    <div class="coverage-item {{ item.status | lower }}">{{ item.name }}</div>
    {% endfor %}
  </div>
  {% else %}
  <p class="text-muted">Coverage data not available.</p>
  {% endif %}
</div>

{# ══════════════════════════════════════════════════════════════════════════
   6. RECOMMENDATIONS
══════════════════════════════════════════════════════════════════════════ #}
<div class="section" id="recommendations">
  <div class="section-header">
    <span class="section-number">6</span>
    <h2>Recommendations</h2>
  </div>

  {% if recommendations %}
  <ol>
    {% for rec in recommendations %}
    <li>
      <strong>{{ rec.title }}</strong>
      {% if rec.priority %} — <span class="badge badge-{{ rec.priority | lower }}">{{ rec.priority }}</span>{% endif %}
      {% if rec.detail %}<p class="mt-sm">{{ rec.detail }}</p>{% endif %}
    </li>
    {% endfor %}
  </ol>
  {% else %}
  <p class="text-muted">No specific recommendations recorded. Review individual finding remediation guidance above.</p>
  {% endif %}
</div>

{# ══════════════════════════════════════════════════════════════════════════
   7. ANALYST NOTES (optional)
══════════════════════════════════════════════════════════════════════════ #}
{% if notes %}
<div class="section" id="notes">
  <div class="section-header">
    <span class="section-number">7</span>
    <h2>Analyst Notes</h2>
  </div>
  <div class="notes-box">{{ notes }}</div>
</div>
{% endif %}

{# ══════════════════════════════════════════════════════════════════════════
   DISCLAIMER
══════════════════════════════════════════════════════════════════════════ #}
<div class="section page-break" id="disclaimer">
  <h2>Disclaimer</h2>
  <div class="disclaimer">
    {{ disclaimer | default("This report was generated automatically by the SCOPE platform. Results reflect the system state at the time of assessment. For internal use only.") }}
  </div>
  <p class="text-muted mt-md">
    Generated by <strong>SCOPE</strong> — Security Configuration Observation and Protection Engine
    {% if generated_at %} &mdash; {{ generated_at }}{% endif %}
  </p>
</div>

</body>
</html>
