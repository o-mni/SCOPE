<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{{ assessment.title | default("Security Assessment Report") }} — SCOPE</title>
  <link rel="stylesheet" href="assets/styles.css" />
</head>
<body>

{# ══════════════════════════════════════════════════════════
   COVER PAGE
══════════════════════════════════════════════════════════ #}
<div class="cover" id="cover">
  <div class="report-label">Preliminary Security Assessment</div>
  <h1>{{ assessment.title | default("Security Assessment Report") }}</h1>

  <div class="cover-meta">
    <div><strong>Target System:</strong> {{ assessment.target | default("N/A") }}</div>
    <div><strong>Assessed by:</strong> {{ assessment.assessor | default("SCOPE Automated Engine") }}</div>
    <div><strong>Assessment Date:</strong> {{ assessment.date | default("—") }}</div>
    <div><strong>Report Generated:</strong> {{ generated_at | default("—") }}</div>
    <div><strong>Assessment ID:</strong> <span class="text-mono">{{ assessment.id | default("N/A") }}</span></div>
    <div><strong>Classification:</strong> {{ assessment.classification | default("Internal Use Only") }}</div>
  </div>
</div>

{# ══════════════════════════════════════════════════════════
   TABLE OF CONTENTS
══════════════════════════════════════════════════════════ #}
{% if render.include_toc %}
<div class="toc page-break" id="toc">
  <h2>Table of Contents</h2>
  <ol>
    <li><a href="#executive-summary">Executive Summary</a></li>
    <li><a href="#scope-methodology">Scope &amp; Methodology</a></li>
    <li><a href="#system-overview">System Overview</a></li>
    <li><a href="#findings">Findings</a>
      <ol>
        <li><a href="#findings-critical">Critical</a></li>
        <li><a href="#findings-high">High</a></li>
        <li><a href="#findings-medium">Medium</a></li>
        <li><a href="#findings-low">Low</a></li>
        <li><a href="#findings-info">Informational</a></li>
      </ol>
    </li>
    <li><a href="#coverage">Assessment Coverage</a></li>
    <li><a href="#recommendations">Recommendations</a></li>
    {% if notes %}<li><a href="#notes">Analyst Notes</a></li>{% endif %}
    <li><a href="#disclaimer">Disclaimer</a></li>
  </ol>
</div>
{% endif %}

{# ══════════════════════════════════════════════════════════
   EXECUTIVE SUMMARY
══════════════════════════════════════════════════════════ #}
<div class="section page-break" id="executive-summary">
  <div class="section-header">
    <span class="section-number">1</span>
    <h2>Executive Summary</h2>
  </div>

  <p>{{ assessment.summary | default("This report presents the findings of an automated preliminary security assessment conducted by the SCOPE platform. The assessment evaluated the target system against a baseline of security configuration checks and known vulnerability indicators.") }}</p>

  {# Severity summary cards #}
  <div class="severity-summary">
    {% for sev in ["critical", "high", "medium", "low", "informational"] %}
    <div class="severity-card {{ sev }}">
      <div class="sev-count">{{ findings_by_severity[sev] | default([]) | length }}</div>
      <div class="sev-label">{{ sev | capitalize }}</div>
    </div>
    {% endfor %}
  </div>

  {% if assessment.risk_statement %}
  <p>{{ assessment.risk_statement }}</p>
  {% endif %}
</div>

{# ══════════════════════════════════════════════════════════
   SCOPE & METHODOLOGY
══════════════════════════════════════════════════════════ #}
<div class="section" id="scope-methodology">
  <div class="section-header">
    <span class="section-number">2</span>
    <h2>Scope &amp; Methodology</h2>
  </div>

  <h3>Assessment Scope</h3>
  <p>{{ assessment.scope | default("The assessment covered the system configuration, installed packages, running services, network exposure, user accounts, file permissions, and security hardening baseline.") }}</p>

  {% if assessment.out_of_scope %}
  <h3>Out of Scope</h3>
  <p>{{ assessment.out_of_scope }}</p>
  {% endif %}

  <h3>Methodology</h3>
  <p>{{ assessment.methodology | default("SCOPE performed a non-intrusive, read-only audit of local system state. No exploits or active probes were used. All data was collected via OS-native interfaces and configuration files.") }}</p>

  {% if assessment.modules_used %}
  <h4>Modules Executed</h4>
  <table>
    <thead>
      <tr>
        <th>Module</th>
        <th>Description</th>
        <th>Status</th>
      </tr>
    </thead>
    <tbody>
      {% for mod in assessment.modules_used %}
      <tr>
        <td class="text-mono">{{ mod.id }}</td>
        <td>{{ mod.description }}</td>
        <td><span class="badge badge-{{ mod.status | lower }}">{{ mod.status }}</span></td>
      </tr>
      {% endfor %}
    </tbody>
  </table>
  {% endif %}
</div>

{# ══════════════════════════════════════════════════════════
   SYSTEM OVERVIEW
══════════════════════════════════════════════════════════ #}
<div class="section" id="system-overview">
  <div class="section-header">
    <span class="section-number">3</span>
    <h2>System Overview</h2>
  </div>

  {% if system %}
  <table>
    <tbody>
      <tr><td><strong>Hostname</strong></td><td class="text-mono">{{ system.hostname | default("—") }}</td></tr>
      <tr><td><strong>OS</strong></td><td>{{ system.os | default("—") }}</td></tr>
      <tr><td><strong>Kernel</strong></td><td class="text-mono">{{ system.kernel | default("—") }}</td></tr>
      <tr><td><strong>Architecture</strong></td><td>{{ system.arch | default("—") }}</td></tr>
      <tr><td><strong>Uptime</strong></td><td>{{ system.uptime | default("—") }}</td></tr>
      <tr><td><strong>Users</strong></td><td>{{ system.users | default("—") }}</td></tr>
      <tr><td><strong>IP Addresses</strong></td><td class="text-mono">{{ system.ip_addresses | join(", ") if system.ip_addresses else "—" }}</td></tr>
    </tbody>
  </table>
  {% else %}
  <p class="text-muted">System information was not collected during this assessment.</p>
  {% endif %}
</div>

{# ══════════════════════════════════════════════════════════
   FINDINGS
══════════════════════════════════════════════════════════ #}
<div class="section page-break" id="findings">
  <div class="section-header">
    <span class="section-number">4</span>
    <h2>Findings</h2>
  </div>

  {% if findings | length == 0 %}
  <p class="text-muted">No findings were recorded for this assessment.</p>
  {% else %}

  {# — All findings summary table — #}
  <h3>Finding Index</h3>
  <table>
    <thead>
      <tr>
        <th>#</th>
        <th>ID</th>
        <th>Title</th>
        <th>Severity</th>
        <th>Category</th>
      </tr>
    </thead>
    <tbody>
      {% for f in findings %}
      <tr>
        <td>{{ loop.index }}</td>
        <td class="text-mono"><a href="#finding-{{ f.id }}">{{ f.id }}</a></td>
        <td>{{ f.title }}</td>
        <td><span class="badge badge-{{ f.severity | lower }}">{{ f.severity }}</span></td>
        <td>{{ f.category | default("—") }}</td>
      </tr>
      {% endfor %}
    </tbody>
  </table>

  {# — Findings by severity — #}
  {% for sev in ["critical", "high", "medium", "low", "informational"] %}
  {% set group = findings_by_severity[sev] | default([]) %}
  {% if group | length > 0 %}

  <h3 id="findings-{{ sev }}">
    <span class="badge badge-{{ sev }}">{{ sev | capitalize }}</span>
    Findings <span class="text-muted">({{ group | length }})</span>
  </h3>

  {% for f in group %}
  <div class="finding-card" id="finding-{{ f.id }}">
    <div class="finding-card-header">
      <span class="finding-id">{{ f.id }}</span>
      <span class="finding-title">{{ f.title }}</span>
      <span class="badge badge-{{ f.severity | lower }}">{{ f.severity }}</span>
    </div>
    <div class="finding-card-body">
      <dl>
        <dt>Description</dt>
        <dd>{{ f.description | default("No description provided.") }}</dd>

        <dt>Category</dt>
        <dd>{{ f.category | default("—") }}</dd>

        {% if f.affected_item %}
        <dt>Affected Item</dt>
        <dd class="text-mono">{{ f.affected_item }}</dd>
        {% endif %}

        {% if f.evidence %}
        <dt>Evidence</dt>
        <dd><pre>{{ f.evidence }}</pre></dd>
        {% endif %}

        {% if f.remediation %}
        <dt>Remediation</dt>
        <dd>{{ f.remediation }}</dd>
        {% endif %}

        {% if f.references %}
        <dt>References</dt>
        <dd>
          {% for ref in f.references %}
            <div>{{ ref }}</div>
          {% endfor %}
        </dd>
        {% endif %}
      </dl>
    </div>
  </div>
  {% endfor %}

  {% endif %}
  {% endfor %}

  {% endif %} {# end findings check #}
</div>

{# ══════════════════════════════════════════════════════════
   ASSESSMENT COVERAGE
══════════════════════════════════════════════════════════ #}
<div class="section page-break" id="coverage">
  <div class="section-header">
    <span class="section-number">5</span>
    <h2>Assessment Coverage</h2>
  </div>

  <p>The following checks were attempted during this assessment:</p>

  {% if coverage %}
  <div class="coverage-grid">
    {% for item in coverage %}
    <div class="coverage-item {{ item.status | lower }}">
      <span>{{ item.name }}</span>
    </div>
    {% endfor %}
  </div>
  {% else %}
  <p class="text-muted">Coverage data not available.</p>
  {% endif %}
</div>

{# ══════════════════════════════════════════════════════════
   RECOMMENDATIONS
══════════════════════════════════════════════════════════ #}
<div class="section" id="recommendations">
  <div class="section-header">
    <span class="section-number">6</span>
    <h2>Recommendations</h2>
  </div>

  {% if recommendations %}
  <ol>
    {% for rec in recommendations %}
    <li>
      <strong>{{ rec.title }}</strong>
      {% if rec.detail %}<p>{{ rec.detail }}</p>{% endif %}
      {% if rec.priority %}<span class="badge badge-{{ rec.priority | lower }}">{{ rec.priority }}</span>{% endif %}
    </li>
    {% endfor %}
  </ol>
  {% else %}
  <p class="text-muted">No specific recommendations recorded.</p>
  {% endif %}
</div>

{# ══════════════════════════════════════════════════════════
   ANALYST NOTES
══════════════════════════════════════════════════════════ #}
{% if notes %}
<div class="section" id="notes">
  <div class="section-header">
    <span class="section-number">7</span>
    <h2>Analyst Notes</h2>
  </div>
  <div class="notes-box">{{ notes }}</div>
</div>
{% endif %}

{# ══════════════════════════════════════════════════════════
   DISCLAIMER
══════════════════════════════════════════════════════════ #}
<div class="section page-break" id="disclaimer">
  <h2>Disclaimer</h2>
  <div class="disclaimer">
    {{ disclaimer | default("This report was generated automatically by the SCOPE platform. Results reflect the system state at the time of assessment. For internal use only.") }}
  </div>
  <p class="text-muted mt-lg">
    Report generated by <strong>SCOPE</strong> — Security Configuration Observation and Protection Engine
    {% if generated_at %} &mdash; {{ generated_at }}{% endif %}
  </p>
</div>

</body>
</html>
